{
  "name": "tospudo",
  "version": "1.0.0",
  "description": "A tool to manage TODOs in your project.",
  "type": "module",
  "bin": {
    "tospudo": "./src/cli.ts"
  },
  "files": [
    "src",
    "schema.json"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "knip": "knip",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:meta": "vitest run tests/meta"
  },
  "keywords": [],
  "author": "hayrdenhald",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "cac": "7.0.0",
    "cosmiconfig": "9.0.1",
    "fast-glob": "3.3.3",
    "ignore": "7.0.5",
    "picocolors": "1.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "25.5.0",
    "knip": "6.2.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
